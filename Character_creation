function buildFeatList(){
  const el = document.getElementById('featList');
  el.innerHTML = '';
  const searchEl = document.getElementById('featSearch');
  const query = searchEl ? searchEl.value.trim().toLowerCase() : '';

  let list = currentFeatCat==='All'
    ? FEATS_LIST
    : FEATS_LIST.filter(f => f.cat===currentFeatCat);

  if(query){
    list = list.filter(f =>
      f.name.toLowerCase().includes(query) ||
      f.benefit.toLowerCase().includes(query) ||
      f.cat.toLowerCase().includes(query)
    );
  }

  if(list.length === 0){
    el.innerHTML = `<div style="font-size:9px;color:var(--text4);padding:12px;text-align:center;letter-spacing:0.08em;">No feats match "${query}"</div>`;
    document.getElementById('featCounter').textContent = `${C.feats.length} / 2 selected`;
    return;
  }

  list.forEach((f,rawIdx)=>{
    const globalIdx = FEATS_LIST.indexOf(f);
    const {met, reasons} = checkPrereqs(f);
    const isSelected = C.feats.includes(f.name);
    const d = document.createElement('div');
    d.className = 'feat-item' + (isSelected?' selected':'') + (!met?' locked':'');

    const lockIcon = !met ? '<span class="feat-lock-icon">🔒</span>' : '';
    const missingLine = !met
      ? `<div class="feat-prereq-line">✗ ${reasons[0]}${reasons.length>1?' +'+( reasons.length-1)+' more':''}</div>`
      : '';

    d.innerHTML = `
      <div class="feat-check">${isSelected?'✓':''}</div>
      <div class="feat-body">
        <div class="feat-name">${f.name}</div>
        <div class="feat-benefit-line">${f.benefit}</div>
        ${missingLine}
      </div>
      <div class="feat-right">
        <span class="feat-tag">${f.cat}</span>
        ${lockIcon}
      </div>`;

    d.onclick = ()=> openFeatOverlay(globalIdx);
    el.appendChild(d);
  });

  document.getElementById('featCounter').textContent = `${C.feats.length} / 2 selected`;
}

function openFeatOverlay(idx){
  const f = FEATS_LIST[idx];
  featOverlayIndex = idx;
  const {met, reasons} = checkPrereqs(f);
  const isSelected = C.feats.includes(f.name);

  document.getElementById('featOvTitle').textContent = f.name;
  document.getElementById('featOvTag').textContent = f.cat;
  document.getElementById('featOvDesc').textContent = f.benefit;

  // Prereqs block
  const p = f.prereqs;
  const hasPrereqs = Object.keys(p).length > 0 || f.special;
  const preEl = document.getElementById('featOvPrereqs');
  if(hasPrereqs){
    const reqs = [];
    if(p.str) reqs.push(`STR ${p.str}`);
    if(p.dex) reqs.push(`DEX ${p.dex}`);
    if(p.con) reqs.push(`CON ${p.con}`);
    if(p.int) reqs.push(`INT ${p.int}`);
    if(p.wis) reqs.push(`WIS ${p.wis}`);
    if(p.cha) reqs.push(`CHA ${p.cha}`);
    if(p.bab) reqs.push(`BAB +${p.bab}`);
    if(p.feats) p.feats.forEach(r=>reqs.push(`Feat: ${r}`));
    if(f.special) reqs.push(f.special);
    preEl.innerHTML = `<div style="font-size:8px;color:var(--text4);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:4px;">Prerequisites</div>`
      + reqs.map(r=>{
          const reqMet = checkSingleReq(r,f);
          return `<div style="font-size:9px;color:${reqMet?'var(--green2)':'var(--red2)'};padding:1px 0;">${reqMet?'✓':'✗'} ${r}</div>`;
        }).join('');
  } else {
    preEl.innerHTML = `<div style="font-size:9px;color:var(--green2);">✓ No prerequisites</div>`;
  }

  // Unmet reasons
  const metEl = document.getElementById('featOvMetStatus');
  if(!met){
    metEl.innerHTML = `<div style="background:rgba(192,64,48,0.1);border:1px solid var(--red);border-radius:2px;padding:6px 10px;color:var(--red2);font-size:9px;line-height:1.6;">`
      + reasons.map(r=>`✗ ${r}`).join('<br>') + '</div>';
  } else {
    metEl.innerHTML = `<div style="font-size:9px;color:var(--green2);">All prerequisites met.</div>`;
  }

  // Select button
  const btn = document.getElementById('featOvSelectBtn');
  if(isSelected){
    btn.textContent = '✓ Selected — tap to deselect';
    btn.style.background = 'rgba(200,134,10,0.15)';
    btn.style.color = 'var(--amber2)';
    btn.style.border = '1px solid var(--amber)';
  } else if(!met){
    btn.textContent = 'Prerequisites not met';
    btn.style.background = 'var(--bg4)';
    btn.style.color = 'var(--text4)';
    btn.style.border = '1px solid var(--b)';
  } else if(C.feats.length>=2 && !isSelected){
    btn.textContent = 'Maximum 2 feats already selected';
    btn.style.background = 'var(--bg4)';
    btn.style.color = 'var(--text4)';
    btn.style.border = '1px solid var(--b)';
  } else {
    btn.textContent = 'Select this feat';
    btn.style.background = 'var(--amber)';
    btn.style.color = 'var(--bg)';
    btn.style.border = 'none';
  }

  document.getElementById('featOverlay').style.display = 'block';
}

function checkSingleReq(reqStr, feat){
  const p = feat.prereqs;
  if(reqStr.startsWith('STR')) return C.attrs.STR >= (p.str||0);
  if(reqStr.startsWith('DEX')) return C.attrs.DEX >= (p.dex||0);
  if(reqStr.startsWith('CON')) return C.attrs.CON >= (p.con||0);
  if(reqStr.startsWith('INT')) return C.attrs.INT >= (p.int||0);
  if(reqStr.startsWith('WIS')) return C.attrs.WIS >= (p.wis||0);
  if(reqStr.startsWith('CHA')) return C.attrs.CHA >= (p.cha||0);
  if(reqStr.startsWith('BAB')) return 1 >= (p.bab||0);
  if(reqStr.startsWith('Feat:')) return C.feats.includes(reqStr.replace('Feat: ',''));
  return true; // special requirements shown as-is
}

function selectFeatFromOverlay(){
  const f = FEATS_LIST[featOverlayIndex];
  const {met} = checkPrereqs(f);
  const isSelected = C.feats.includes(f.name);

  if(isSelected){
    C.feats = C.feats.filter(x=>x!==f.name);
    notify(`${f.name} deselected`);
    closeFeatOverlay();
    buildFeatList();
    return;
  }
  if(!met){ notify('Prerequisites not met'); return; }
  if(C.feats.length>=2){ notify('Maximum 2 feats — deselect one first'); return; }

  C.feats.push(f.name);
  notify(`${f.name} selected (${C.feats.length}/2)`);
  closeFeatOverlay();
  buildFeatList();
}

function clearFeatSearch(){
  const el = document.getElementById('featSearch');
  if(el){ el.value=''; el.focus(); }
  buildFeatList();
}

function closeFeatOverlay(){
  document.getElementById('featOverlay').style.display = 'none';
  featOverlayIndex = null;
}

