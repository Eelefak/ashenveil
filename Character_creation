let currentFeatCat = 'All';
let featOverlayIndex = null;

function checkPrereqs(feat){
  const p = feat.prereqs;
  const reasons = [];
  if(p.str  && C.attrs.STR < p.str)  reasons.push(`STR ${p.str} required (you have ${C.attrs.STR||'—'})`);
  if(p.dex  && C.attrs.DEX < p.dex)  reasons.push(`DEX ${p.dex} required (you have ${C.attrs.DEX||'—'})`);
  if(p.con  && C.attrs.CON < p.con)  reasons.push(`CON ${p.con} required (you have ${C.attrs.CON||'—'})`);
  if(p.int  && C.attrs.INT < p.int)  reasons.push(`INT ${p.int} required (you have ${C.attrs.INT||'—'})`);
  if(p.wis  && C.attrs.WIS < p.wis)  reasons.push(`WIS ${p.wis} required (you have ${C.attrs.WIS||'—'})`);
  if(p.cha  && C.attrs.CHA < p.cha)  reasons.push(`CHA ${p.cha} required (you have ${C.attrs.CHA||'—'})`);
  if(p.bab  && 1 < p.bab)            reasons.push(`BAB +${p.bab} required (starting BAB +1)`);
  if(p.feats){
    p.feats.forEach(req=>{
      if(!C.feats.includes(req)) reasons.push(`Requires feat: ${req}`);
    });
  }
  return {met: reasons.length===0, reasons};
}

