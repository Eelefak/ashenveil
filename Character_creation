// ── RECOMMENDED ATTRIBUTE DISTRIBUTION ────────────────────────────────────
const CLASS_STAT_PRIORITY = {
  Barbarian: ['STR','CON','DEX','WIS','INT','CHA'],
  Bard:      ['CHA','DEX','CON','INT','WIS','STR'],
  Cleric:    ['WIS','CON','STR','CHA','INT','DEX'],
  Druid:     ['WIS','CON','DEX','INT','CHA','STR'],
  Warrior:   ['STR','CON','DEX','WIS','INT','CHA'],
  Monk:      ['WIS','DEX','STR','CON','INT','CHA'],
  Paladin:   ['STR','CHA','CON','WIS','DEX','INT'],
  Ranger:    ['DEX','STR','WIS','CON','INT','CHA'],
  Rogue:     ['DEX','INT','CON','WIS','CHA','STR'],
  Sorcerer:  ['CHA','CON','DEX','INT','WIS','STR'],
  Wizard:    ['INT','DEX','CON','WIS','CHA','STR'],
};

function recommendedDistribution(){
  if(!rolledValues || rolledValues.length === 0){
    notify('Roll your values first'); return;
  }
  if(!C.class){ notify('Choose your class first'); return; }
  const priority = CLASS_STAT_PRIORITY[C.class] || ['STR','DEX','CON','INT','WIS','CHA'];

  // Reset all assignments
  ATTRS_LIST.forEach(a=>{
    C.attrs[a.key]=0;
    document.getElementById('av-'+a.key).textContent='—';
    document.getElementById('ab-'+a.key).textContent='—';
    document.getElementById('ab-'+a.key).className='attr-bonus';
    document.getElementById('ar-'+a.key).innerHTML='';
    document.getElementById('attr-'+a.key).classList.remove('assigned','awaiting');
  });
  rolledValues.forEach(v=>{ v.used=false; v.assignedTo=null; });

  // Sort rolled values descending
  const sorted = [...rolledValues].sort((a,b)=>b.value-a.value);

  // Assign best value to most important stat
  priority.forEach((key,i)=>{
    if(!sorted[i]) return;
    const entry = sorted[i];
    entry.used=true; entry.assignedTo=key;
    C.attrs[key]=entry.value;
    const m=mod(entry.value);
    const mStr=(m>=0?'+':'')+m;
    document.getElementById('av-'+key).textContent=entry.value;
    const bEl=document.getElementById('ab-'+key);
    bEl.textContent=mStr;
    bEl.className='attr-bonus'+(m>0?' pos':m<0?' neg':'');
    document.getElementById('ar-'+key).innerHTML=
      `<button class="unassign-btn" onclick="event.stopPropagation();unassignStat('${key}')">✕</button>`;
    document.getElementById('attr-'+key).classList.add('assigned');
  });

  renderPool();
  notify('Assigned for '+C.class+' — adjust freely');
}
// ── ATTRIBUTE ROLL + ASSIGN SYSTEM ───────────────────────────────────────
let rolledValues = [];   // [{value, rollStr, index, used, assignedTo}]
let selectedPoolIndex = null; // which pool chip is selected

function buildAttrRows(){
  const el = document.getElementById('attrRows');
  ATTRS_LIST.forEach(a => {
    const d = document.createElement('div');
    d.className = 'attr-row';
