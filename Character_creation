// Init ranks on SKILLS_DATA
SKILLS_DATA.forEach(s => { if(s.ranks===undefined) s.ranks=0; });

let skillFilterMode = 'All'; // All | Class | Cross

function getSkillPointsAvailable(){
  const cls = C.class;
  if(!cls) return 0;
  const base = CLASS_SKILL_POINTS[cls] || 2;
  const intMod = mod(C.attrs.INT||10);
  const perLevel = Math.max(1, base + intMod);
  const isHuman = C.race === 'Human';
  return (perLevel + (isHuman ? 1 : 0)) * 4; // level 1 ×4
}

function getSkillPointsSpent(){
  return SKILLS_DATA.reduce((total, s) => {
    const isClass = isClassSkill(s.name);
    return total + (isClass ? s.ranks : s.ranks * 2);
  }, 0);
}

function isClassSkill(skillName){
  const cls = C.class;
  if(!cls) return false;
  const list = CLASS_SKILLS[cls] || [];
  return list.some(cs => skillName.startsWith(cs) || cs.startsWith(skillName.split(' ')[0]));
}

function getMaxRank(isClass){
  return isClass ? 4 : 2; // level 1 max: class=4, cross=2
}

function buildSkillFilters(){
  const el = document.getElementById('skillFilterTabs');
  if(!el) return;
  el.innerHTML = '';
  ['All','Class skills','Cross-class'].forEach(label => {
    const d = document.createElement('div');
    d.className = 'shop-tab' + (skillFilterMode===label?' on':'');
    d.textContent = label;
    d.style.fontSize = '8px';
    d.onclick = () => { skillFilterMode=label; buildSkillRows(); buildSkillFilters(); };
    el.appendChild(d);
  });
}

function buildSkillRows(){
  const el = document.getElementById('skillRows');
  el.innerHTML = '';

  const available = getSkillPointsAvailable();
  const spent = getSkillPointsSpent();
  const remaining = available - spent;

  // Update header
  const counter = document.getElementById('skillPointsCounter');
  if(counter){
    counter.textContent = `${remaining} points remaining`;
    counter.style.color = remaining < 0 ? 'var(--red2)' : remaining === 0 ? 'var(--green2)' : '';
  }

  const info = document.getElementById('skillPointsInfo');
  if(info && C.class){
    const base = CLASS_SKILL_POINTS[C.class]||2;
    const intMod = mod(C.attrs.INT||10);
    const isHuman = C.race==='Human';
    info.innerHTML = `<strong style="color:var(--text2)">${C.class}</strong>: ${base} base + ${intMod>=0?'+':''}${intMod} INT${isHuman?' +1 Human':''} = <span style="color:var(--amber2)">${Math.max(1,base+intMod)+(isHuman?1:0)}/level ×4 = ${available} points</span> &nbsp;|&nbsp; <span style="color:var(--amber)">Amber = class skill (max rank 4) &nbsp; Grey = cross-class (max rank 2, costs 2pts)</span>`;
  } else if(info){
    info.textContent = 'Select your class and assign attributes first.';
  }

  // Filter
  let list = SKILLS_DATA;
  if(skillFilterMode === 'Class skills') list = SKILLS_DATA.filter(s => isClassSkill(s.name));
  if(skillFilterMode === 'Cross-class')  list = SKILLS_DATA.filter(s => !isClassSkill(s.name));

  list.forEach(s => {
    const isClass = isClassSkill(s.name);
    const maxRank = getMaxRank(isClass);
    const costPer = isClass ? 1 : 2;
    const m = s.ab === '—' ? 0 : mod(C.attrs[s.ab]||10);
    const total = m + s.ranks;
    const totalStr = (total >= 0 ? '+' : '') + total;

    const canAdd = remaining >= costPer && s.ranks < maxRank;
    const canSub = s.ranks > 0;

    const d = document.createElement('div');
    d.className = 'skill-row ' + (isClass ? 'class-skill' : 'cross-skill');

    d.innerHTML = `
      <div class="skill-name-wrap" onclick="showSkillDetail(${JSON.stringify(s).replace(/"/g,"'")})">
        <span class="skill-name">${s.name}</span>
        <span class="${isClass?'skill-class-tag':'skill-cross-tag'}">${isClass?'Class skill':'Cross-class (×2)'} · ${s.ab}</span>
      </div>
      <span class="skill-ab" style="color:${m>0?'var(--green2)':m<0?'var(--red2)':'var(--text4)'};">${s.ab==='—'?'—':(m>=0?'+':'')+m}</span>
      <span class="skill-total ${total<0?'neg':''}">${s.ab==='—'?'—':totalStr}</span>
      <div class="rank-ctrl">
        <button class="rank-btn" ${canSub?'':'disabled'} onclick="changeRank('${s.name}',-1)">−</button>
        <span class="rank-val">${s.ranks}</span>
        <button class="rank-btn" ${canAdd?'':'disabled'} onclick="changeRank('${s.name}',1)">+</button>
      </div>`;

    el.appendChild(d);
  });

  if(list.length === 0){
    el.innerHTML = '<div style="font-size:9px;color:var(--text4);padding:16px;text-align:center;font-style:italic;">No skills in this category.</div>';
  }
}

function changeRank(skillName, delta){
  const s = SKILLS_DATA.find(sk => sk.name === skillName);
  if(!s) return;
  const isClass = isClassSkill(s.name);
  const costPer = isClass ? 1 : 2;
  const maxRank = getMaxRank(isClass);
  const available = getSkillPointsAvailable();
  const spent = getSkillPointsSpent();
  const remaining = available - spent;

  if(delta > 0){
    if(s.ranks >= maxRank){ notify(`Max rank for this skill is ${maxRank}`); return; }
    if(remaining < costPer){ notify(`Not enough points — need ${costPer}, have ${remaining}`); return; }
    s.ranks++;
  } else {
    if(s.ranks <= 0) return;
    s.ranks--;
  }
  buildSkillRows();
}

function resetSkills(){
  SKILLS_DATA.forEach(s => s.ranks = 0);
  buildSkillRows();
  notify('All skill ranks reset');
}

function showSkillDetail(s){
  if(typeof s === 'string') s = JSON.parse(s);
  const isClass = isClassSkill(s.name);
  const costPer = isClass ? 1 : 2;
  const maxRank = getMaxRank(isClass);
  const m = s.ab === '—' ? 0 : mod(C.attrs[s.ab]||10);
  document.getElementById('overlayTitle').textContent = s.name;
  document.getElementById('overlayBody').innerHTML =
    `<div style="margin-bottom:8px;">${s.desc}</div>
     <div style="font-size:9px;color:var(--text4);line-height:1.8;">
       Key ability: <span style="color:var(--text2)">${s.ab}</span><br>
       Modifier: <span style="color:${m>=0?'var(--green2)':'var(--red2)'}">${m>=0?'+':''}${m}</span><br>
       Type: <span style="color:${isClass?'var(--amber)':'var(--text3)'}">${isClass?'Class skill':'Cross-class skill'}</span><br>
       Cost per rank: <span style="color:var(--text2)">${costPer} point${costPer>1?'s':''}</span><br>
       Max rank at level 1: <span style="color:var(--text2)">${maxRank}</span>
     </div>`;
  document.getElementById('skillOverlay').classList.add('show');
}
function closeOverlay(){ document.getElementById('skillOverlay').classList.remove('show'); }

