}

function showAttrDesc(a){
  document.querySelectorAll('.attr-row').forEach(r => r.classList.remove('active'));
  document.getElementById('attr-' + a.key).classList.add('active');
  document.getElementById('activeAttrDesc').innerHTML =
    `<div class="desc-title">${a.name}</div><div class="desc-text">${a.desc}<br><br>${a.detail}</div>`;
}

function rollDie(sides, show){
  const r = Math.floor(Math.random() * sides) + 1;
  if(show){
    const ov = document.getElementById('diceOverlay');
    document.getElementById('diceNum').textContent = r;
    document.getElementById('diceNum').style.color = r===sides?'var(--amber3)':r===1?'var(--red2)':'var(--amber2)';
    document.getElementById('diceLbl').textContent = `d${sides}${r===sides?' — critical!':r===1?' — fumble!':''}`;
    ov.classList.add('show');
    setTimeout(()=>ov.classList.remove('show'), 700);
  }
  return r;
}

function roll4d6(){
  const rolls = [1,2,3,4].map(() => Math.floor(Math.random()*6)+1);
  const min = Math.min(...rolls);
  const kept = [...rolls]; kept.splice(kept.indexOf(min), 1);
  const total = kept.reduce((a,b) => a+b, 0);
  const rollStr = rolls.map(r => r===min ? `(${r})` : r).join(', ');
  return {total, rollStr};
}

function rollAll(){
  // Clear all current assignments first
  ATTRS_LIST.forEach(a => {
    C.attrs[a.key] = 0;
    document.getElementById('av-' + a.key).textContent = '—';
    document.getElementById('ab-' + a.key).textContent = '—';
    document.getElementById('ab-' + a.key).className = 'attr-bonus';
    document.getElementById('ar-' + a.key).innerHTML = '';
    const row = document.getElementById('attr-' + a.key);
    row.classList.remove('assigned','awaiting');
  });
  selectedPoolIndex = null;

  // Roll 6 new values
  rolledValues = Array.from({length:6}, (_,i) => {
    const {total, rollStr} = roll4d6();
    return {value: total, rollStr, index: i, used: false, assignedTo: null};
  });
  // Sort descending for display
  const sorted = [...rolledValues].sort((a,b) => b.value - a.value);
  rolledValues = sorted.map((v,i) => ({...v, index:i}));

  rollDie(20, true);
  renderPool();
  document.getElementById('rollAllBtn').textContent = 'Reroll All Values';
}

function renderPool(){
  const el = document.getElementById('rollPool');
  el.innerHTML = '';
  rolledValues.forEach((v, i) => {
    const chip = document.createElement('div');
    chip.className = 'pool-chip' +
      (v.used ? ' used' : '') +
      (selectedPoolIndex === i ? ' selected' : '');
    const m = mod(v.value);
    chip.innerHTML = `${v.value}<span class="chip-sub">${m>=0?'+':''}${m}</span>`;
    chip.title = `Rolled: ${v.rollStr}`;
    if(!v.used){
      chip.onclick = () => selectPoolChip(i);
    }
    el.appendChild(chip);
  });

  // Summary of assigned
  const assigned = rolledValues.filter(v => v.used);
  if(assigned.length > 0){
    const sum = document.createElement('div');
    sum.className = 'summary-row';
    sum.style.width = '100%';
    sum.style.marginTop = '6px';
    sum.innerHTML = `${assigned.length}/6 assigned &nbsp;`;
    if(assigned.length === 6) sum.innerHTML += '<span style="color:var(--green2);">All assigned ✓</span>';
    el.appendChild(sum);
  }
}

function selectPoolChip(i){
  if(rolledValues[i].used) return;
  selectedPoolIndex = i === selectedPoolIndex ? null : i;
  renderPool();
  // Highlight all unassigned stat rows as awaiting
  ATTRS_LIST.forEach(a => {
    const row = document.getElementById('attr-' + a.key);
    if(C.attrs[a.key] === 0 && selectedPoolIndex !== null){
      row.classList.add('awaiting');
    } else {
      row.classList.remove('awaiting');
    }
  });
  if(selectedPoolIndex !== null){
    notify(`Value ${rolledValues[i].value} selected — tap a stat to assign it`);
  }
}

function assignToStat(key){
  if(selectedPoolIndex === null){
    // If stat already has a value, unassign it
    if(C.attrs[key] > 0){
      const poolEntry = rolledValues.find(v => v.assignedTo === key);
      if(poolEntry){
        poolEntry.used = false;
        poolEntry.assignedTo = null;
      }
      C.attrs[key] = 0;
      document.getElementById('av-' + key).textContent = '—';
      document.getElementById('ab-' + key).textContent = '—';
      document.getElementById('ab-' + key).className = 'attr-bonus';
      document.getElementById('ar-' + key).innerHTML = '';
      document.getElementById('attr-' + key).classList.remove('assigned');
      renderPool();
      notify('Value unassigned from ' + key);
    } else {
      notify('Select a rolled value first, then tap a stat');
    }
    return;
  }

  // If stat already assigned — swap
  if(C.attrs[key] > 0){
    const oldEntry = rolledValues.find(v => v.assignedTo === key);
    if(oldEntry){
      oldEntry.used = false;
      oldEntry.assignedTo = null;
    }
  }

  // Assign selected pool value to this stat
  const entry = rolledValues[selectedPoolIndex];
  entry.used = true;
  entry.assignedTo = key;
  C.attrs[key] = entry.value;

  const m = mod(entry.value);
  const mStr = (m>=0?'+':'') + m;
  document.getElementById('av-' + key).textContent = entry.value;
  const bEl = document.getElementById('ab-' + key);
  bEl.textContent = mStr;
  bEl.className = 'attr-bonus' + (m>0?' pos':m<0?' neg':'');

  // Show the roll breakdown
  document.getElementById('ar-' + key).innerHTML =
    `<button class="unassign-btn" onclick="event.stopPropagation();unassignStat('${key}')">✕</button>`;

  const row = document.getElementById('attr-' + key);
  row.classList.remove('awaiting');
  row.classList.add('assigned');

  selectedPoolIndex = null;
  renderPool();

  // Clear awaiting state from all rows
  ATTRS_LIST.forEach(a => document.getElementById('attr-' + a.key).classList.remove('awaiting'));

  // Check if all assigned
  const allDone = rolledValues.every(v => v.used);
  if(allDone) notify('All attributes assigned! Looking good.');
}

function unassignStat(key){
  const entry = rolledValues.find(v => v.assignedTo === key);
  if(entry){
    entry.used = false;
    entry.assignedTo = null;
  }
  C.attrs[key] = 0;
  document.getElementById('av-' + key).textContent = '—';
  document.getElementById('ab-' + key).textContent = '—';
  document.getElementById('ab-' + key).className = 'attr-bonus';
  document.getElementById('ar-' + key).innerHTML = '';
  document.getElementById('attr-' + key).classList.remove('assigned');
  renderPool();
  notify(key + ' unassigned — value returned to pool');
}

