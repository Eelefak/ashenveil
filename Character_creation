  const rec = RECOMMENDED_GEAR[cls];
  if(!rec){ notify('No recommendation available for ' + cls); return; }

  // Reset current gear and gold
  const startGold = CLASS_GOLD[cls] || 100;
  C.gold = startGold;
  C.gear = [];

  // Buy each recommended item if affordable
  const bought = [];
  const skipped = [];
  rec.items.forEach(itemName => {
    // Find item across all shop categories
    let found = null;
    SHOP_CATS.forEach(cat => {
      cat.items.forEach(item => {
        if(item.name === itemName) found = item;
      });
    });
    if(!found){ skipped.push(itemName); return; }
    if(C.gold >= found.price){
      C.gold -= found.price;
      C.gear.push(found.name);
      bought.push(found.name);
    } else {
      skipped.push(itemName + ' (too expensive)');
    }
  });

  document.getElementById('goldVal').textContent = C.gold + ' gp';

  // Show note
  const note = document.getElementById('shopGoldNote');
  if(note) note.innerHTML = `<span style="color:var(--amber2);">${cls} recommended kit applied.</span> ${rec.note} &nbsp;<span style="color:var(--text4);">${C.gold}gp remaining.</span>`;

  // Refresh current tab
  setShopCat(currentShopCat);
  notify(`Equipped ${bought.length} items for ${cls}`);
}
function initShopGold(){
  const classGold = CLASS_GOLD[C.class] || 100;
  C.gold = classGold;
  document.getElementById('goldVal').textContent = C.gold + ' gp';
  const note = document.getElementById('shopGoldNote');
  if(note) note.textContent = `Starting gold for ${C.class||'your class'}: ${classGold} gp (PHB average)`;
}

let currentShopCat=0;
function buildShop(){
  const tabs=document.getElementById('shopTabs');
  SHOP_CATS.forEach((c,i)=>{
    const d=document.createElement('div');
    d.className='shop-tab'+(i===0?' on':'');
    d.textContent=c.name;
    d.onclick=()=>setShopCat(i);
    tabs.appendChild(d);
  });
  setShopCat(0);
}

function setShopCat(i){
  currentShopCat=i;
  const cat=SHOP_CATS[i];
  document.querySelectorAll('.shop-tab').forEach((t,ti)=>t.classList.toggle('on',ti===i));
  document.getElementById('shopCatDesc').textContent=cat.desc;
  const el=document.getElementById('shopItems');
  el.innerHTML='';
  cat.items.forEach(item=>{
    const owned=C.gear.includes(item.name);
    const canAfford=C.gold>=item.price;
    const d=document.createElement('div');
    d.className='shop-item'+(owned?' owned':'')+((!owned&&!canAfford)?' cant-afford':'');
    const priceColor=owned?'var(--green2)':!canAfford?'var(--red2)':'var(--amber2)';
    const extraInfo=item.dmg?`<span style="color:var(--text4);font-size:8px;margin-right:6px;">dmg ${item.dmg}</span>`
      :item.ac?`<span style="color:var(--text4);font-size:8px;margin-right:6px;">AC ${item.ac}</span>`:'';
    const typeTag=item.type?`<span style="font-size:7px;color:var(--text4);border:1px solid var(--b);padding:1px 4px;border-radius:2px;margin-right:4px;">${item.type}</span>`:'';
    const wt=item.wt?`<span style="font-size:7px;color:var(--text4);">${item.wt}</span>`:'';
    d.innerHTML=`
      <span class="si-icon">${item.icon}</span>
      <div class="si-info">
        <div class="si-name">${item.name}</div>
        <div class="si-desc">${item.desc}</div>
        <div style="margin-top:3px;display:flex;align-items:center;flex-wrap:wrap;gap:2px;">${typeTag}${extraInfo}${wt}</div>
      </div>
      <span class="si-price" style="color:${priceColor};">${owned?'✓ Owned':item.price===0?'Free':item.price+' gp'}</span>`;
    d.onclick=()=>buyItem(item);
    el.appendChild(d);
  });
}

function buyItem(item){
  if(C.gear.includes(item.name)){
    // Allow selling back
    C.gear=C.gear.filter(x=>x!==item.name);
    C.gold+=item.price;
    document.getElementById('goldVal').textContent=C.gold+' gp';
    setShopCat(currentShopCat);
    notify('Sold: '+item.name+' (+'+item.price+'gp)');
    return;
  }
  if(C.gold<item.price){notify('Not enough gold (need '+item.price+'gp)');return;}
  C.gold-=item.price;
  C.gear.push(item.name);
  document.getElementById('goldVal').textContent=C.gold+' gp';
  setShopCat(currentShopCat);
  notify('Purchased: '+item.name);
}

// Portrait grid
function buildPortraitGrid(){
  const el=document.getElementById('portraitGrid');
  const uploadSlot=document.createElement('div');
  uploadSlot.className='portrait-slot upload-slot';
  uploadSlot.innerHTML=`<span class="upload-icon">📤</span><span class="upload-label">Upload</span>`;
  uploadSlot.onclick=()=>notify('Upload coming soon — use a preset for now');
  el.appendChild(uploadSlot);
  PORTRAITS.forEach((p,i)=>{
    const d=document.createElement('div');
    d.className='portrait-slot';
    d.textContent=p;
    d.onclick=()=>{
      C.portrait=p;
      document.querySelectorAll('.portrait-slot').forEach(s=>s.classList.remove('selected'));
      d.classList.add('selected');
    };
    el.appendChild(d);
  });
}

// Character sheet summary
function buildSheet(){
  C.name=document.getElementById('charName').value||'Unknown';
  document.getElementById('sheetPortrait').textContent=C.portrait;
  document.getElementById('sheetName').textContent=C.name;
  document.getElementById('sheetMeta').textContent=
    [C.gender,C.race,C.class,C.origin].filter(Boolean).join(' · ')||'No selections made';
  const statsEl=document.getElementById('sheetStats');
  statsEl.innerHTML='';
  ATTRS_LIST.forEach(a=>{
    const v=C.attrs[a.key]; const m=mod(v);
    statsEl.innerHTML+=`<div class="sheet-stat"><div class="ss-name">${a.key}</div><div class="ss-val">${v}</div><div class="ss-mod">${m>=0?'+':''}${m}</div></div>`;
  });
  const combatEl=document.getElementById('sheetCombat');
  const dex=mod(C.attrs.DEX), con=mod(C.attrs.CON), str=mod(C.attrs.STR);
  const baseAC=10+dex+(C.gear.includes('Chain Shirt')?4:C.gear.includes('Leather Armour')?2:0)+(C.gear.includes('Shield (heavy)')?2:0);
  combatEl.innerHTML=`
    <div class="cs-box"><div class="cs-label">AC</div><div class="cs-val">${baseAC}</div></div>
    <div class="cs-box"><div class="cs-label">HP</div><div class="cs-val">${10+con}</div></div>
    <div class="cs-box"><div class="cs-label">Init</div><div class="cs-val">${dex>=0?'+':''}${dex}</div></div>
    <div class="cs-box"><div class="cs-label">BAB</div><div class="cs-val">+1</div></div>`;
  const savesEl=document.getElementById('sheetSaves');
  savesEl.innerHTML=`
    <div class="cs-box"><div class="cs-label">Fort</div><div class="cs-val">${con>=0?'+':''}${con+2}</div></div>
    <div class="cs-box"><div class="cs-label">Ref</div><div class="cs-val">${dex>=0?'+':''}${dex+0}</div></div>
    <div class="cs-box"><div class="cs-label">Will</div><div class="cs-val">${mod(C.attrs.WIS)>=0?'+':''}${mod(C.attrs.WIS)+0}</div></div>
    <div class="cs-box"><div class="cs-label">FF AC</div><div class="cs-val">${baseAC-dex}</div></div>`;
  const gearEl=document.getElementById('sheetGear');
  gearEl.innerHTML=C.gear.length?C.gear.map(g=>`<div class="gear-item">${g}</div>`).join(''):'<div class="gear-item" style="color:var(--text4);">No equipment purchased</div>';
}

// ── NAVIGATION ────────────────────────────────────────────────────────────
function goTo(n){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById('s'+n).classList.add('active');
  document.getElementById('progressFill').style.width=Math.round((n/10)*100)+'%';
  window.scrollTo(0,0);
  if(n===6){ buildFeatFilters(); buildFeatList(); }
  if(n===7){ buildSkillFilters(); buildSkillRows(); }
  if(n===8) initShopGold();
  if(n===10) buildSheet();
}

function selectGender(g){
  C.gender=g;
  document.getElementById('gFemale').classList.toggle('selected',g==='Female');
  document.getElementById('gMale').classList.toggle('selected',g==='Male');
  document.getElementById('genderDescTitle').textContent=g;
  document.getElementById('genderDescText').textContent=g==='Female'?
    'You move through Ashenveil as a woman. Some underestimate you. Their mistake.':
    'You move through Ashenveil as a man. The world reads you as it reads all men — until you prove otherwise.';
}

function notify(msg){
  let n=document.getElementById('notif');
  if(!n){n=document.createElement('div');n.id='notif';n.style.cssText='position:fixed;bottom:20px;left:50%;transform:translateX(-50%);background:#1a1208;border:1px solid #c8860a;border-radius:3px;padding:8px 16px;font-size:10px;color:#e8a020;letter-spacing:0.08em;z-index:9999;opacity:0;transition:opacity .2s;';document.body.appendChild(n);}
  n.textContent=msg;n.style.opacity=1;
  setTimeout(()=>n.style.opacity=0,2200);
}

function startGame(){
  const conMod = Math.floor((C.attrs.CON-10)/2);
  const classHpMap = {Barbarian:12,Bard:8,Cleric:8,Druid:8,Warrior:10,Monk:8,Paladin:10,Ranger:8,Rogue:6,Sorcerer:4,Wizard:4};
  const baseHp = (classHpMap[C.class]||8) + conMod;
  const skills = {};
  SKILLS_DATA.forEach(s=>{ if(s.ranks>0) skills[s.name]=s.ranks; });
  const character = {
    name:  C.name  || 'Adventurer',
    cls:   C.class || 'Warrior',
    race:  C.race  || 'Human',
    gender: C.gender || 'Unknown',
    origin: C.origin || '',
    attrs: C.attrs,
    skills,
    hp:    Math.max(1, baseHp),
    maxHp: Math.max(1, baseHp),
    gold:  Math.floor(C.gold || 14),
    gear:  C.gear  || [],
    feats: C.feats || [],
    portrait: C.portrait || '',
  };
  try{ localStorage.setItem('ashenveil_character', JSON.stringify(character)); }catch(e){}
  notify('Entering Ashenveil...');
  setTimeout(()=>window.location.href='game.html', 1000);
}

// ── INIT ──────────────────────────────────────────────────────────────────
buildRaceCarousel();
buildOriginList();
buildClassGrid();
buildAttrRows();
buildFeatFilters();
buildFeatList();
buildSkillFilters();
buildSkillRows();
buildShop();
buildPortraitGrid();
</script>
