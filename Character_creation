<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Ashenveil — Character Creation</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Cinzel:wght@400;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
:root{
  --bg:#0d0a07;--bg2:#110e08;--bg3:#1a1208;--bg4:#221608;
  --b:#2a1e0e;--b2:#3a2510;--b3:#5a3e1b;
  --amber:#c8860a;--amber2:#e8a020;--amber3:#f0c050;
  --text:#d4b483;--text2:#a07840;--text3:#7a5a2a;--text4:#5a3e1b;
  --red:#c04030;--red2:#e05040;
  --green:#2a6a2a;--green2:#4a8a4a;
  --ft:'Cinzel',serif;--fm:'Share Tech Mono',monospace;
}
html,body{background:var(--bg);color:var(--text);font-family:var(--fm);min-height:100vh;display:flex;justify-content:center;align-items:flex-start;}
.app{width:390px;max-width:100vw;min-height:100vh;display:flex;flex-direction:column;position:relative;overflow:hidden;}

/* PROGRESS BAR */
.progress-bar{height:3px;background:var(--bg3);position:relative;}
.progress-fill{height:100%;background:var(--amber);transition:width .4s;}

/* SCREEN */
.screen{display:none;flex-direction:column;flex:1;min-height:calc(100vh - 3px);}
.screen.active{display:flex;}

/* HEADER */
.screen-header{padding:18px 20px 10px;text-align:center;}
.screen-title{font-family:var(--ft);font-size:18px;color:var(--amber);letter-spacing:0.15em;margin-bottom:4px;}
.screen-sub{font-size:9px;color:var(--text4);letter-spacing:0.15em;text-transform:uppercase;}

/* SCROLL BODY */
.screen-body{flex:1;overflow-y:auto;padding:10px 16px;display:flex;flex-direction:column;gap:12px;}
.screen-body::-webkit-scrollbar{width:2px;}
.screen-body::-webkit-scrollbar-thumb{background:var(--b3);}

/* NAV */
.nav{padding:12px 16px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--b);background:var(--bg2);flex-shrink:0;}
.nav-btn{font-family:var(--fm);font-size:11px;padding:10px 24px;border-radius:3px;border:none;cursor:pointer;letter-spacing:0.12em;transition:all .15s;}
.nav-back{background:var(--red);color:#fff;}
.nav-back:hover{background:var(--red2);}
.nav-next{background:var(--green);color:#fff;}
.nav-next:hover{background:var(--green2);}
.nav-btn:disabled{opacity:.3;cursor:not-allowed;}
.step-indicator{font-size:9px;color:var(--text4);letter-spacing:0.1em;}

/* DESCRIPTION BOX */
.desc-box{background:var(--bg3);border:1px solid var(--b2);border-radius:3px;padding:12px 14px;}
.desc-box .desc-title{font-family:var(--ft);font-size:11px;color:var(--amber2);margin-bottom:6px;letter-spacing:0.08em;}
.desc-box .desc-text{font-size:10px;color:var(--text3);line-height:1.75;letter-spacing:0.02em;}
.desc-box .pros-cons{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px;}
.desc-box .pro-col .col-title{font-size:8px;color:var(--green2);letter-spacing:0.15em;text-transform:uppercase;margin-bottom:4px;}
.desc-box .con-col .col-title{font-size:8px;color:var(--red2);letter-spacing:0.15em;text-transform:uppercase;margin-bottom:4px;}
.desc-box .pro-item,.desc-box .con-item{font-size:9px;color:var(--text3);line-height:1.6;padding-left:8px;position:relative;}
.desc-box .pro-item::before{content:'+ ';color:var(--green2);position:absolute;left:0;}
.desc-box .con-item::before{content:'− ';color:var(--red2);position:absolute;left:0;}

/* GENDER */
.gender-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.gender-card{background:var(--bg3);border:1px solid var(--b);border-radius:3px;padding:20px 10px;text-align:center;cursor:pointer;transition:all .15s;}
.gender-card.selected{border-color:var(--amber);background:rgba(200,134,10,0.08);}
.gender-card:hover{border-color:var(--b3);}
.gender-icon{font-size:40px;margin-bottom:8px;display:block;}
.gender-name{font-family:var(--ft);font-size:13px;color:var(--text2);letter-spacing:0.1em;}
.gender-card.selected .gender-name{color:var(--amber2);}

/* RACE CAROUSEL */
.carousel-wrap{position:relative;display:flex;flex-direction:column;align-items:center;gap:12px;}
.carousel-main{display:flex;align-items:center;justify-content:center;gap:12px;width:100%;}
.carousel-arrow{background:var(--bg3);border:1px solid var(--b2);border-radius:3px;width:40px;height:40px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px;color:var(--text2);transition:all .15s;flex-shrink:0;}
.carousel-arrow:hover{border-color:var(--amber);color:var(--amber);}
.carousel-arrow:active{transform:scale(0.94);}
.race-card-main{flex:1;background:var(--bg3);border:1px solid var(--amber);border-radius:3px;padding:20px 16px;text-align:center;transition:all .25s;}
.race-art-main{width:120px;height:120px;border-radius:3px;margin:0 auto 12px;background:var(--bg2);border:1px solid var(--b2);display:flex;align-items:center;justify-content:center;font-size:56px;}
.race-name-main{font-family:var(--ft);font-size:15px;color:var(--amber2);letter-spacing:0.1em;margin-bottom:4px;}
.race-counter{font-size:8px;color:var(--text4);letter-spacing:0.15em;}
.carousel-dots{display:flex;gap:6px;justify-content:center;}
.cdot{width:6px;height:6px;border-radius:50%;background:var(--b2);transition:all .2s;cursor:pointer;}
.cdot.active{background:var(--amber);}

/* ORIGIN LIST */
.origin-list{display:flex;flex-direction:column;gap:6px;}
.origin-item{background:var(--bg3);border:1px solid var(--b);border-radius:3px;padding:12px 14px;cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:10px;}
.origin-item.selected{border-color:var(--amber);background:rgba(200,134,10,0.08);}
.origin-item:hover{border-color:var(--b3);}
.origin-dot{width:8px;height:8px;border-radius:50%;border:1px solid var(--b3);flex-shrink:0;transition:all .15s;}
.origin-item.selected .origin-dot{background:var(--amber);border-color:var(--amber);}
.origin-name{font-family:var(--ft);font-size:11px;color:var(--text2);letter-spacing:0.08em;}
.origin-item.selected .origin-name{color:var(--amber2);}
.origin-tag{font-size:8px;color:var(--text4);margin-left:auto;letter-spacing:0.08em;}

/* CLASS GRID */
.class-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;}
.class-card{background:var(--bg3);border:1px solid var(--b);border-radius:3px;padding:10px 6px;text-align:center;cursor:pointer;transition:all .15s;}
.class-card.selected{border-color:var(--amber);background:rgba(200,134,10,0.08);}
.class-card:hover{border-color:var(--b3);}
.class-icon{font-size:22px;margin-bottom:4px;display:block;}
.class-name{font-size:9px;color:var(--text2);letter-spacing:0.06em;}
.class-card.selected .class-name{color:var(--amber2);}

/* ATTRIBUTES */
.attr-table{background:var(--bg3);border:1px solid var(--b);border-radius:3px;overflow:hidden;}
.attr-header{display:grid;grid-template-columns:1fr 60px 50px 50px;gap:0;padding:6px 12px;background:var(--bg4);border-bottom:1px solid var(--b);}
.attr-header span{font-size:8px;color:var(--text4);letter-spacing:0.12em;text-transform:uppercase;}
.attr-row{display:grid;grid-template-columns:1fr 60px 50px 50px;gap:0;padding:9px 12px;border-bottom:1px solid var(--b);align-items:center;cursor:pointer;transition:background .15s;}
.attr-row:last-child{border-bottom:none;}
.attr-row:hover{background:var(--bg4);}
.attr-row.active{background:rgba(200,134,10,0.06);}
.attr-name{font-size:10px;color:var(--text2);letter-spacing:0.05em;}
.attr-val{font-family:var(--ft);font-size:16px;color:var(--amber2);text-align:center;}
.attr-bonus{font-size:11px;color:var(--text3);text-align:center;}
.attr-bonus.pos{color:var(--green2);}
.attr-bonus.neg{color:var(--red2);}
.attr-roll-result{font-size:9px;color:var(--text4);text-align:center;}
.pool-chip{display:inline-flex;align-items:center;justify-content:center;min-width:40px;height:36px;background:var(--bg4);border:1px solid var(--b2);border-radius:3px;font-family:var(--ft);font-size:15px;color:var(--amber2);cursor:pointer;transition:all .15s;padding:0 8px;position:relative;}
.pool-chip:hover{border-color:var(--amber);background:rgba(200,134,10,0.1);}
.pool-chip.selected{border-color:var(--amber3);background:rgba(240,192,80,0.15);color:var(--amber3);box-shadow:0 0 0 1px var(--amber3);}
.pool-chip.used{opacity:.3;cursor:not-allowed;text-decoration:line-through;}
.pool-chip .chip-sub{position:absolute;bottom:1px;right:3px;font-size:6px;color:var(--text4);font-family:var(--fm);}
.unassign-btn{font-family:var(--fm);font-size:8px;color:var(--text4);background:transparent;border:1px solid var(--b);padding:2px 7px;border-radius:2px;cursor:pointer;letter-spacing:0.08em;transition:all .12s;}
.unassign-btn:hover{color:var(--red2);border-color:var(--red2);}
.assign-hint{font-size:8px;color:var(--amber);letter-spacing:0.08em;animation:fade 1s infinite;}
.attr-row.awaiting{background:rgba(200,134,10,0.06);border-left:2px solid var(--amber);}
.attr-row.assigned{background:rgba(42,106,42,0.05);}
.summary-row{display:flex;gap:6px;flex-wrap:wrap;font-size:9px;color:var(--text4);padding:4px 0;letter-spacing:0.06em;}
.summary-row span{color:var(--amber2);}

/* FEATS */
.feat-list{display:flex;flex-direction:column;gap:5px;overflow-y:auto;max-height:420px;padding-right:4px;}
.feat-item{background:var(--bg3);border:1px solid var(--b);border-radius:3px;padding:10px 12px;cursor:pointer;transition:all .15s;display:flex;align-items:flex-start;gap:10px;}
.feat-item.selected{border-color:var(--amber);background:rgba(200,134,10,0.08);}
.feat-item:hover:not(.locked){border-color:var(--b3);}
.feat-item.locked{opacity:.38;cursor:pointer;}
.feat-item.locked:hover{border-color:var(--b2);}
.feat-check{width:16px;height:16px;border:1px solid var(--b3);border-radius:2px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:10px;margin-top:1px;}
.feat-item.selected .feat-check{background:var(--amber);border-color:var(--amber);color:var(--bg);}
.feat-item.locked .feat-check{border-color:var(--b);background:var(--bg2);}
.feat-body{flex:1;min-width:0;}
.feat-name{font-size:10px;color:var(--text2);letter-spacing:0.04em;margin-bottom:2px;}
.feat-item.selected .feat-name{color:var(--amber2);}
.feat-item.locked .feat-name{color:var(--text4);}
.feat-prereq-line{font-size:8px;color:var(--red2);letter-spacing:0.04em;margin-top:1px;}
.feat-benefit-line{font-size:8px;color:var(--text3);letter-spacing:0.03em;line-height:1.4;}
.feat-right{display:flex;flex-direction:column;align-items:flex-end;gap:3px;flex-shrink:0;}
.feat-tag{font-size:7px;color:var(--text4);letter-spacing:0.08em;border:1px solid var(--b);padding:1px 5px;border-radius:2px;}
.feat-lock-icon{font-size:10px;color:var(--text4);}
.feat-counter{font-family:var(--ft);font-size:13px;color:var(--amber);letter-spacing:0.1em;text-align:center;}

/* SKILLS */
.skill-row{display:grid;grid-template-columns:1fr 36px 44px 72px;padding:7px 16px;border-bottom:1px solid var(--b);align-items:center;transition:background .1s;}
.skill-row:last-child{border-bottom:none;}
.skill-row:hover{background:var(--bg4);}
.skill-row.class-skill{border-left:2px solid var(--amber);}
.skill-row.cross-skill{border-left:2px solid var(--b2);}
.skill-name-wrap{display:flex;flex-direction:column;gap:1px;cursor:pointer;}
.skill-name{font-size:9px;color:var(--text2);letter-spacing:0.03em;}
.skill-class-tag{font-size:7px;color:var(--amber);letter-spacing:0.08em;}
.skill-cross-tag{font-size:7px;color:var(--text4);letter-spacing:0.08em;}
.skill-ab{font-size:8px;color:var(--text4);text-align:center;}
.skill-total{font-family:var(--ft);font-size:12px;color:var(--amber2);text-align:center;}
.skill-total.neg{color:var(--red2);}
.rank-ctrl{display:flex;align-items:center;justify-content:center;gap:4px;}
.rank-btn{width:22px;height:22px;border-radius:2px;border:1px solid var(--b2);background:var(--bg3);color:var(--text2);font-size:14px;line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .1s;flex-shrink:0;font-family:var(--fm);}
.rank-btn:hover:not(:disabled){border-color:var(--amber);color:var(--amber);}
.rank-btn:disabled{opacity:.25;cursor:not-allowed;}
.rank-val{font-family:var(--ft);font-size:13px;color:var(--amber2);min-width:16px;text-align:center;}
.skill-hint{font-size:8px;color:var(--text4);text-align:center;padding:6px;letter-spacing:0.08em;}

/* SKILL DETAIL OVERLAY */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:100;display:none;align-items:flex-end;justify-content:center;}
.overlay.show{display:flex;}
.overlay-card{background:var(--bg3);border:1px solid var(--b3);border-radius:6px 6px 0 0;padding:20px;width:390px;max-width:100vw;max-height:60vh;overflow-y:auto;}
.overlay-title{font-family:var(--ft);font-size:14px;color:var(--amber2);margin-bottom:8px;letter-spacing:0.1em;}
.overlay-close{position:absolute;top:14px;right:16px;font-size:18px;color:var(--text4);cursor:pointer;background:transparent;border:none;}

/* SHOP */
.shop-tabs{display:flex;gap:0;border-bottom:1px solid var(--b);overflow-x:auto;scrollbar-width:none;}
.shop-tabs::-webkit-scrollbar{display:none;}
.shop-tab{font-family:var(--fm);font-size:8px;color:var(--text4);padding:8px 12px;border-bottom:2px solid transparent;cursor:pointer;white-space:nowrap;letter-spacing:0.1em;text-transform:uppercase;transition:all .12s;flex-shrink:0;}
.shop-tab.on{color:var(--amber);border-bottom-color:var(--amber);}
.shop-items{display:flex;flex-direction:column;gap:6px;}
.shop-item{background:var(--bg3);border:1px solid var(--b);border-radius:3px;padding:10px 12px;display:flex;align-items:center;gap:10px;cursor:pointer;transition:all .12s;}
.shop-item:hover{border-color:var(--b3);}
.shop-item.cant-afford{opacity:.5;}
.shop-item.owned{border-color:var(--green);background:rgba(42,106,42,0.06);}
.si-icon{font-size:18px;width:28px;text-align:center;flex-shrink:0;}
.si-info{flex:1;}
.si-name{font-size:10px;color:var(--text2);letter-spacing:0.04em;margin-bottom:2px;}
.si-desc{font-size:8px;color:var(--text4);letter-spacing:0.03em;}
.si-price{font-family:var(--ft);font-size:12px;color:var(--amber2);flex-shrink:0;}
.si-price.owned{color:var(--green2);font-size:10px;}
.gold-bar{background:var(--bg3);border:1px solid var(--b);border-radius:3px;padding:8px 14px;display:flex;align-items:center;justify-content:space-between;}
.gold-label{font-size:9px;color:var(--text4);letter-spacing:0.1em;text-transform:uppercase;}
.gold-val{font-family:var(--ft);font-size:14px;color:var(--amber2);}
.shop-cat-desc{font-size:9px;color:var(--text3);line-height:1.7;letter-spacing:0.03em;}

/* PORTRAIT */
.portrait-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;}
.portrait-slot{aspect-ratio:3/4;background:var(--bg3);border:1px solid var(--b);border-radius:3px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .15s;font-size:28px;position:relative;overflow:hidden;}
.portrait-slot.selected{border-color:var(--amber);box-shadow:0 0 0 1px var(--amber);}
.portrait-slot:hover{border-color:var(--b3);}
.portrait-slot.upload-slot{flex-direction:column;gap:4px;}
.portrait-slot .upload-icon{font-size:22px;color:var(--text4);}
.portrait-slot .upload-label{font-size:8px;color:var(--text4);letter-spacing:0.1em;}
.name-input{width:100%;background:var(--bg3);border:1px solid var(--b2);border-radius:3px;padding:12px 14px;font-family:var(--ft);font-size:14px;color:var(--amber2);outline:none;letter-spacing:0.08em;text-align:center;}
.name-input::placeholder{color:var(--b3);}
.name-input:focus{border-color:var(--amber);}

/* CHARACTER SHEET SUMMARY */
.sheet-portrait-row{display:grid;grid-template-columns:90px 1fr;gap:12px;align-items:start;}
.sheet-portrait{aspect-ratio:3/4;background:var(--bg3);border:1px solid var(--b2);border-radius:3px;display:flex;align-items:center;justify-content:center;font-size:40px;}
.sheet-identity{display:flex;flex-direction:column;gap:4px;}
.sheet-name{font-family:var(--ft);font-size:16px;color:var(--amber2);letter-spacing:0.1em;}
.sheet-meta{font-size:9px;color:var(--text3);letter-spacing:0.06em;line-height:1.7;}
.sheet-section{background:var(--bg3);border:1px solid var(--b);border-radius:3px;overflow:hidden;}
.sheet-sec-title{font-family:var(--ft);font-size:9px;color:var(--amber);letter-spacing:0.2em;text-transform:uppercase;padding:6px 12px;background:var(--bg4);border-bottom:1px solid var(--b);}
.sheet-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:0;}
.sheet-stat{padding:8px 6px;text-align:center;border-right:1px solid var(--b);border-bottom:1px solid var(--b);}
.sheet-stat:nth-child(3n){border-right:none;}
.sheet-stat .ss-name{font-size:7px;color:var(--text4);letter-spacing:0.12em;text-transform:uppercase;}
.sheet-stat .ss-val{font-family:var(--ft);font-size:18px;color:var(--amber2);}
.sheet-stat .ss-mod{font-size:9px;color:var(--text3);}
.combat-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:0;}
.cs-box{padding:8px 4px;text-align:center;border-right:1px solid var(--b);}
.cs-box:last-child{border-right:none;}
.cs-box .cs-label{font-size:7px;color:var(--text4);letter-spacing:0.1em;text-transform:uppercase;}
.cs-box .cs-val{font-family:var(--ft);font-size:16px;color:var(--amber2);}
.gear-list{padding:8px 12px;display:flex;flex-direction:column;gap:4px;}
.gear-item{font-size:9px;color:var(--text3);padding:3px 0;border-bottom:1px solid var(--b);letter-spacing:0.04em;}
.gear-item:last-child{border-bottom:none;}
.start-btn{background:var(--amber);color:var(--bg);font-family:var(--ft);font-size:13px;padding:14px;border:none;border-radius:3px;cursor:pointer;letter-spacing:0.2em;width:100%;transition:all .15s;}
.start-btn:hover{background:var(--amber2);}

/* DICE OVERLAY */
.dice-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:200;display:none;align-items:center;justify-content:center;}
.dice-overlay.show{display:flex;}
.dice-box{background:var(--bg3);border:1px solid var(--amber);border-radius:4px;padding:24px 36px;text-align:center;}
.dice-num{font-family:var(--ft);font-size:64px;color:var(--amber2);line-height:1;}
.dice-lbl{font-size:10px;color:var(--text3);letter-spacing:0.15em;margin-top:6px;}

.scanlines{position:fixed;inset:0;background:repeating-linear-gradient(to bottom,transparent 0,transparent 3px,rgba(0,0,0,0.08) 3px,rgba(0,0,0,0.08) 4px);pointer-events:none;z-index:9999;}
</style>
</head>
<body>
<div class="scanlines"></div>
<div class="dice-overlay" id="diceOverlay">
  <div class="dice-box">
    <div class="dice-num" id="diceNum">—</div>
    <div class="dice-lbl" id="diceLbl">rolling...</div>
  </div>
</div>
<div class="overlay" id="skillOverlay" onclick="closeOverlay()">
  <div class="overlay-card" onclick="event.stopPropagation()">
    <button class="overlay-close" onclick="closeOverlay()">✕</button>
    <div class="overlay-title" id="overlayTitle">Skill Name</div>
    <div class="desc-text" id="overlayBody" style="font-size:10px;color:var(--text3);line-height:1.75;"></div>
  </div>
</div>

<div class="app">
  <div class="progress-bar"><div class="progress-fill" id="progressFill" style="width:10%"></div></div>

  <!-- SCREEN 1: GENDER -->
  <div class="screen active" id="s1">
    <div class="screen-header">
      <div class="screen-title">Who Are You?</div>
      <div class="screen-sub">Choose your gender</div>
    </div>
    <div class="screen-body">
      <div class="gender-row">
        <div class="gender-card" id="gFemale" onclick="selectGender('Female')">
          <span class="gender-icon">♀</span>
          <div class="gender-name">Female</div>
        </div>
        <div class="gender-card" id="gMale" onclick="selectGender('Male')">
          <span class="gender-icon">♂</span>
          <div class="gender-name">Male</div>
        </div>
      </div>
      <div class="desc-box">
        <div class="desc-title" id="genderDescTitle">Select a gender</div>
        <div class="desc-text" id="genderDescText">Your choice shapes how the world of Ashenveil perceives and reacts to you. Some doors open easier. Others close. Neither path is lesser.</div>
      </div>
    </div>
    <div class="nav">
      <button class="nav-btn nav-back" disabled>← Back</button>
